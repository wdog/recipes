#!/usr/bin/env bash
# network-chooser — fast network management via fuzzel + nmcli
set -euo pipefail

FUZZEL_LINES=18
FUZZEL_WIDTH=55

T=$'\t'

notify() {
	notify-send -a "network-chooser" "${1}" "${2:-}" ${3:+-u "$3"}
}

# ── Data collection ───────────────────────────────────────────────────────────

collect_data() {
	CONNS=$(nmcli -t -f NAME,TYPE,STATE connection show 2>/dev/null)
	WIFI_STATE=$(nmcli -t -f WIFI general 2>/dev/null)
	if [[ "$WIFI_STATE" == "enabled" ]]; then
		WIFI_LIST=$(nmcli -t -f IN-USE,SSID,SIGNAL,SECURITY dev wifi list --rescan no 2>/dev/null)
	else
		WIFI_LIST=""
	fi
}

# ── Menu builder ──────────────────────────────────────────────────────────────
# Each line: TAG<TAB>DISPLAY
# fuzzel called with --with-nth=2: shows only DISPLAY, returns full line.
# TAG "." = header/separator, ignored by dispatch.

build_menu() {
	# ── VPN ───────────────────────────────────────────────────────────────────
	local vpn_lines
	vpn_lines=$(echo "$CONNS" | grep -E ":(vpn|wireguard):" | sort -u -t: -k1,1)
	if [[ -n "$vpn_lines" ]]; then
		printf ".\t── VPN ──\n"
		while IFS=: read -r name type state; do
			if [[ "$state" == "activated" ]]; then
				printf "vpn:up:%s\t🔑 %s\n" "$name" "$name"
			else
				printf "vpn:down:%s\t🔌 %s\n" "$name" "$name"
			fi
		done <<<"$vpn_lines"
		printf ".\t\n"
	fi

	# ── WiFi ──────────────────────────────────────────────────────────────────
	printf ".\t── WiFi ──\n"
	if [[ "$WIFI_STATE" == "enabled" ]]; then
		printf "action:wifi-off\t  🚫 Disabilita WiFi\n"
		printf "action:wifi-scan\t  🔍 Scansiona reti\n"
		if [[ -n "$WIFI_LIST" ]]; then
			# Active SSIDs from connection state (more reliable than IN-USE field)
			local active_ssids
			active_ssids=$(echo "$CONNS" | grep ":802-11-wireless:activated" | cut -d: -f1)
			local seen_ssids=()
			while IFS=: read -r in_use ssid signal security; do
				[[ -z "$ssid" ]] && continue
				[[ " ${seen_ssids[*]} " =~ " ${ssid} " ]] && continue
				seen_ssids+=("$ssid")
				local dot="🔌" state="down"
				if echo "$active_ssids" | grep -qx "$ssid"; then
					dot="🛜"
					state="up"
				fi
				local auth="$security"
				[[ "$auth" == "--" ]] && auth="open"
				printf "wifi:%s:%s\t  %s %-22s %3d%% %s\n" \
					"$state" "$ssid" "$dot" "$ssid" "$signal" "$auth"
			done <<<"$(echo "$WIFI_LIST" | sort -t: -k3 -rn)"
		fi
	else
		printf "action:wifi-on\t  💫 Abilita WiFi\n"
	fi
	printf ".\t\n"

	# ── Ethernet ──────────────────────────────────────────────────────────────
	local eth_lines
	eth_lines=$(echo "$CONNS" | grep ":802-3-ethernet:")
	if [[ -n "$eth_lines" ]]; then
		printf ".\t── ETHERNET ──\n"
		while IFS=: read -r name type state; do
			if [[ "$state" == "activated" ]]; then
				printf "eth:up:%s\t  📶 %s\n" "$name" "$name"
			else
				printf "eth:down:%s\t  ○ %s\n" "$name" "$name"
			fi
		done <<<"$eth_lines"
		printf ".\t\n"
	fi

	# ── Azioni ────────────────────────────────────────────────────────────────
	printf ".\t── AZIONI ──\n"
	printf "action:reset\t  🔥 riavvia networking\n"
	printf "action:settings\t  🛠️ impostazioni\n"
}

# ── Handlers ──────────────────────────────────────────────────────────────────

handle_wifi() {
	local state="$1" ssid="$2"
	if [[ "$state" == "up" ]]; then
		nmcli connection down id "$ssid" &>/dev/null &&
			notify "WiFi" "Disconnesso da $ssid" ||
			notify "WiFi" "Errore: $ssid" critical
		return
	fi
	if nmcli -t -f NAME connection show 2>/dev/null | grep -qx "$ssid"; then
		nmcli connection up id "$ssid" &>/dev/null &&
			notify "WiFi" "Connesso: $ssid" ||
			notify "WiFi" "Errore: $ssid" critical
		return
	fi
	local security
	security=$(echo "$WIFI_LIST" | grep -m1 ":${ssid}:" | cut -d: -f4)
	if [[ "$security" != "--" ]] && [[ -n "$security" ]]; then
		local pwd
		pwd=$(printf "" | fuzzel -d -w 40 --password -p "Password $ssid: " 2>/dev/null) || true
		[[ -z "$pwd" ]] && return
		nmcli device wifi connect "$ssid" password "$pwd" &>/dev/null &&
			notify "WiFi" "Connesso: $ssid" ||
			notify "WiFi" "Errore: $ssid" critical
	else
		nmcli device wifi connect "$ssid" &>/dev/null &&
			notify "WiFi" "Connesso: $ssid" ||
			notify "WiFi" "Errore: $ssid" critical
	fi
}

dispatch() {
	local sel="$1"
	# Tag is the first column (before TAB)
	local tag="${sel%%$T*}"
	[[ "$tag" == "." ]] && return # header/separator, ignore

	local kind="${tag%%:*}"   # vpn / wifi / eth / action
	local rest="${tag#*:}"    # state:name  or  subaction
	local state="${rest%%:*}" # up / down / wifi-off / reset / ...
	local name="${rest#*:}"   # connection name or ssid

	case "$kind" in
	vpn)
		if [[ "$state" == "up" ]]; then
			nmcli connection down id "$name" &>/dev/null &&
				notify "VPN" "Disconnesso: $name" ||
				notify "VPN" "Errore: $name" critical
		else
			notify "VPN" "Connessione a $name..."
			nmcli connection up id "$name" &>/dev/null &&
				notify "VPN" "Connesso: $name" ||
				notify "VPN" "Errore: $name" critical
		fi
		;;
	wifi)
		handle_wifi "$state" "$name"
		;;
	eth)
		if [[ "$state" == "up" ]]; then
			nmcli connection down id "$name" &>/dev/null &&
				notify "ETH" "Disconnesso: $name" ||
				notify "ETH" "Errore: $name" critical
		else
			nmcli connection up id "$name" &>/dev/null &&
				notify "ETH" "Connesso: $name" ||
				notify "ETH" "Errore: $name" critical
		fi
		;;
	action)
		case "$state" in
		wifi-on)
			nmcli radio wifi on
			notify "WiFi" "Abilitato"
			;;
		wifi-off)
			nmcli radio wifi off
			notify "WiFi" "Disabilitato"
			;;
		wifi-scan)
			notify "WiFi" "Scansione..."
			nmcli device wifi rescan &>/dev/null || true
			;;
		reset)
			nmcli networking off && sleep 1 && nmcli networking on
			notify "Rete" "Reset completato"
			;;
		settings)
			if command -v nm-connection-editor &>/dev/null; then
				nm-connection-editor &
			elif command -v nmtui &>/dev/null; then
				"${TERMINAL:-xterm}" -e nmtui &
			fi
			;;
		esac
		;;
	esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

for cmd in nmcli fuzzel notify-send; do
	command -v "$cmd" &>/dev/null || {
		echo "Errore: $cmd non trovato" >&2
		exit 1
	}
done

collect_data
selection=$(build_menu | fuzzel -d --with-nth=2 -w "$FUZZEL_WIDTH" -l "$FUZZEL_LINES" -p "rete: " 2>/dev/null) || true
[[ -z "$selection" ]] && exit 0
dispatch "$selection"
